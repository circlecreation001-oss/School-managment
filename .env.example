# ===================================
# Application
# ===================================
NODE_ENV=production
APP_NAME=EducationERP
APP_URL=https://your-frontend-domain.vercel.app
API_URL=https://your-backend-domain.onrender.com
API_PORT=4000
API_PREFIX=/api/v1

# ===================================
# Database (Supabase PostgreSQL)
# ===================================
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ===================================
# Redis (Upstash / Redis Cloud)
# ===================================
REDIS_URL=rediss://default:[YOUR-REDIS-PASSWORD]@[YOUR-REDIS-HOST]:6379
REDIS_HOST=[YOUR-REDIS-HOST]
REDIS_PORT=6379
REDIS_PASSWORD=[YOUR-REDIS-PASSWORD]

# ===================================
# JWT Authentication (CHANGE THESE!)
# ===================================
JWT_ACCESS_SECRET=generate-a-64-char-random-string-here
JWT_REFRESH_SECRET=generate-another-64-char-random-string-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===================================
# Storage (Supabase Storage or S3)
# ===================================
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3
S3_ACCESS_KEY=[YOUR-SUPABASE-SERVICE-KEY]
S3_SECRET_KEY=[YOUR-SUPABASE-SERVICE-KEY]
S3_BUCKET=education-erp
S3_REGION=us-east-1

# ===================================
# Email (SMTP - Resend/SendGrid/Mailgun)
# ===================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=[YOUR-RESEND-API-KEY]
SMTP_FROM_NAME=Education ERP
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ===================================
# SMS (Optional)
# ===================================
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=EDUERP

# ===================================
# WhatsApp (Optional)
# ===================================
WHATSAPP_PROVIDER=console
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ===================================
# Payment Gateway (Optional)
# ===================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ===================================
# Logging
# ===================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# CORS (Add your frontend domain)
# ===================================
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# ===================================
# Encryption
# ===================================
ENCRYPTION_KEY=generate-a-32-char-random-string-here!!
