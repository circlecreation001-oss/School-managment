{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma || true",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "push": "prisma db push --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
